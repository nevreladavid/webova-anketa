<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Výsledky ankety</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h1 class="text-center mb-4">Výsledky ankety</h1>
                <% if (responses.length === 0) { %>
                    <p class="text-center">Žádné odpovědi zatím nejsou.</p>
                <% } else { %>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Jméno</th>
                                <th>Věk</th>
                                <th>Jazyk</th>
                                <th>Úroveň</th>
                                <th>Komentář</th>
                                <th>Čas</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% responses.forEach(response => { %>
                                <tr>
                                    <td><%= response.name %></td>
                                    <td><%= response.age %></td>
                                    <td><%= response.language %></td>
                                    <td><%= response.experience %></td>
                                    <td><%= response.comment || 'Žádný' %></td>
                                    <td><%= response.timestamp %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
                <div class="text-center mt-4">
                    <a href="/" class="btn btn-primary">Zpět na anketu</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>